METEOLENS_ENV=development
METEOLENS_API_BASE_URL=http://localhost:8000
METEOLENS_FRONTEND_ORIGIN=http://localhost:5173
# Administrative HTTP operations are disabled unless this value is set. Keep
# the real production value in a secret manager, never in this file.
METEOLENS_ADMIN_TOKEN=
METEOLENS_DATABASE_URL=sqlite:///data/meteolens.sqlite3
METEOLENS_CACHE_DIR=/data/cache
METEOLENS_GEOMETRY_DIR=/data/geometry
METEOLENS_PRODUCT_DETAIL_CACHE_SECONDS=3600
METEOLENS_PRODUCT_FILE_RETENTION_HOURS=24
METEOLENS_PRODUCT_MAX_CACHED_FILES=500
# Stage 14 product rendering (COSMO 2 m temperature overlay).
METEOLENS_PRODUCT_REFRESH_ENABLED=false
METEOLENS_PRODUCT_REFRESH_IDS=COSMO_HVD_00_00,COSMO_HVD_06_00,COSMO_HVD_12_00,COSMO_HVD_18_00
METEOLENS_PRODUCT_MAX_DETAIL_MANIFESTS=50
METEOLENS_PRODUCT_BINARY_MAX_FILES=4
METEOLENS_PRODUCT_DOWNLOAD_TIMEOUT_SECONDS=180
METEOLENS_PRODUCT_FILE_MAX_MB=300
METEOLENS_PRODUCT_RENDER_MAX_LEAD_HOURS=24
METEOLENS_PRODUCT_RENDER_LEAD_STEP_HOURS=3
METEOLENS_PRODUCT_RENDER_WIDTH=700
METEOLENS_PRODUCT_RENDER_PREFETCH_FRAMES=0
METEOLENS_PRODUCT_RENDER_MAX_CONCURRENT=1
METEOLENS_IMGW_BASE_URL=https://danepubliczne.imgw.pl
METEOLENS_LOG_LEVEL=INFO
METEOLENS_LOG_FORMAT=text
METEOLENS_METRICS_ENABLED=false
METEOLENS_SYNC_ON_STARTUP=false
METEOLENS_REFRESH_ENABLED=false
METEOLENS_REFRESH_SYNOP_SECONDS=600
METEOLENS_REFRESH_HYDRO_SECONDS=600
METEOLENS_REFRESH_METEO_SECONDS=600
METEOLENS_REFRESH_WARNINGS_SECONDS=300
METEOLENS_OBSERVATION_RETENTION_DAYS=30
METEOLENS_ARCHIVE_BACKFILL_COOLDOWN_SECONDS=900
# Bounded SYNOP archive import resource limits (Stage 15 hardening).
METEOLENS_ARCHIVE_BACKFILL_MAX_DAYS=31
METEOLENS_ARCHIVE_BACKFILL_MAX_FILES=12
METEOLENS_ARCHIVE_BACKFILL_RATE_LIMIT_SECONDS=0.5
METEOLENS_ARCHIVE_DOWNLOAD_MAX_MB=50
METEOLENS_ARCHIVE_ZIP_MAX_ENTRIES=10
METEOLENS_ARCHIVE_ZIP_ENTRY_MAX_MB=100
METEOLENS_ARCHIVE_ZIP_TOTAL_UNCOMPRESSED_MAX_MB=150
METEOLENS_ARCHIVE_MAX_ROWS_PER_FILE=50000
METEOLENS_IMGW_TIMEOUT_SECONDS=20
METEOLENS_IMGW_MAX_RETRIES=2
METEOLENS_IMGW_RETRY_DELAY_SECONDS=0.25

# Docker Compose host port mapping. Compose reads these from a project-root
# `.env` file or the shell (not from env_file), so copy what you need into
# `.env` or set them inline, e.g. `BACKEND_PORT=8010 docker compose up`.
BACKEND_PORT=8000
FRONTEND_PORT=5173
