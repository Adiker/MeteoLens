# Production environment template for docker compose -f docker-compose.prod.yml
# Copy to .env.production and adjust before deployment.

METEOLENS_ENV=production
METEOLENS_LOG_LEVEL=INFO
METEOLENS_LOG_FORMAT=json
METEOLENS_METRICS_ENABLED=true
METEOLENS_FRONTEND_ORIGIN=https://meteolens.example.com
# Required to enable archive imports. Leave empty to disable all administrative
# HTTP operations (the safe default). Store the real value outside git.
METEOLENS_ADMIN_TOKEN=
METEOLENS_DATABASE_URL=sqlite:////data/meteolens.sqlite3
METEOLENS_CACHE_DIR=/data/cache
METEOLENS_IMGW_BASE_URL=https://danepubliczne.imgw.pl
METEOLENS_SYNC_ON_STARTUP=true
METEOLENS_REFRESH_ENABLED=true
METEOLENS_REFRESH_SYNOP_SECONDS=600
METEOLENS_REFRESH_HYDRO_SECONDS=600
METEOLENS_REFRESH_METEO_SECONDS=600
METEOLENS_REFRESH_WARNINGS_SECONDS=300
METEOLENS_IMGW_TIMEOUT_SECONDS=20
METEOLENS_IMGW_MAX_RETRIES=2
METEOLENS_IMGW_RETRY_DELAY_SECONDS=0.25
METEOLENS_PRODUCT_RENDER_MAX_CONCURRENT=1
METEOLENS_ARCHIVE_BACKFILL_COOLDOWN_SECONDS=900

# Host port for the public HTTP entrypoint (nginx serves static UI + /api proxy).
PUBLIC_HTTP_PORT=8080
PROMETHEUS_HTTP_PORT=9090
METEOLENS_BACKUP_DIR=./backups
BACKEND_CPUS=2.0
BACKEND_MEMORY=2g
FRONTEND_CPUS=0.5
FRONTEND_MEMORY=256m
PROMETHEUS_CPUS=0.5
PROMETHEUS_MEMORY=512m
DATA_OPS_CPUS=1.0
DATA_OPS_MEMORY=1g
DATA_INIT_CPUS=0.5
DATA_INIT_MEMORY=512m
PROMETHEUS_INIT_CPUS=0.25
PROMETHEUS_INIT_MEMORY=128m
CONTAINER_LOG_MAX_SIZE=10m
CONTAINER_LOG_MAX_FILES=5
