# Example Caddy site block for TLS termination in front of MeteoLens.
# Replace example.com and email before use.

{
    email you@example.com
}

example.com {
    encode gzip

    # Keep nginx as the single application entrypoint so API/render limits,
    # timeouts, security headers, and access logging cannot be bypassed.
    reverse_proxy frontend:8080
}
