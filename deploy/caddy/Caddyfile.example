# Example Caddy site block for TLS termination in front of MeteoLens.
# Replace example.com and email before use.

{
    email you@example.com
}

example.com {
    encode gzip

    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /health {
        reverse_proxy backend:8000
    }

    handle {
        reverse_proxy frontend:80
    }
}
