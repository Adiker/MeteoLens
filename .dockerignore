# Build context filter for images built from the repository root
# (frontend/Dockerfile.prod). Only the frontend sources and the nginx config
# are needed; everything else — especially the local ./data bind mount, which
# can contain container-owned cache files unreadable by the build — stays out.
*
!frontend/
!deploy/nginx/
frontend/node_modules/
frontend/dist/
frontend/coverage/
frontend/.vite/
frontend/playwright-report/
frontend/test-results/
